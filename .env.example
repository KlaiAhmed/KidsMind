# =============================================================================
# KidsMind Root Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in your values.
# This file configures Docker Compose and infrastructure services.


# =============================================================================
# APP & RUNTIME
# =============================================================================

# Production mode toggle. Set to True only in production.
# False enables dev auth bypass and relaxed rate limits.
IS_PROD=False

# Global logging level for all services.
# Options: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO


# =============================================================================
# NETWORK & PORTS
# =============================================================================

# Public API bind configuration
API_BIND_HOST=0.0.0.0
API_PORT=8000

# Debug ports (only used when docker-compose.debug.yml is loaded)
AI_PORT=8001
STT_PORT=8002
DB_PORT=5432
STORAGE_API_PORT=9000
STORAGE_CONSOLE_PORT=9001
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
LOKI_PORT=3100
POSTGRES_EXPORTER_PORT=9187
REDIS_EXPORTER_PORT=9121


# =============================================================================
# DOCKER COMPOSE
# =============================================================================

# Compose file selection - controls which compose files are loaded.
# Docker reads this variable automatically.
# Use the correct separator: ":" on Linux/macOS, ";" on Windows

# Development: base + override (local dev with hot reload)
#   COMPOSE_FILE=docker-compose.yml;docker-compose.override.yml

# Debug: base + override + debug (exposes internal services to localhost)
#   COMPOSE_FILE=docker-compose.yml;docker-compose.override.yml;docker-compose.debug.yml

# Production: base only (NEVER use override/debug in production)
#   COMPOSE_FILE=docker-compose.yml

COMPOSE_FILE=docker-compose.yml;docker-compose.override.yml


# =============================================================================
# SERVICE DISCOVERY (Core API Upstream Services)
# =============================================================================

# Internal URLs for inter-service communication (used by core-api only)
STT_SERVICE_URL=http://stt-service:8000


# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================

DB_USER=your_postgres_username
DB_PASSWORD=your_postgres_password
DB_NAME=your_database_name


# =============================================================================
# CACHE (Redis)
# =============================================================================

CACHE_PASSWORD=your_redis_password


# =============================================================================
# OBJECT STORAGE (MinIO)
# =============================================================================

STORAGE_ROOT_USER=your_minio_root_username
STORAGE_ROOT_PASSWORD=your_minio_root_password


# =============================================================================
# MONITORING (Grafana)
# =============================================================================

GRAFANA_ADMIN_USER=your_grafana_admin_username
GRAFANA_ADMIN_PASSWORD=your_grafana_admin_password
