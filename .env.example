# Environment mode
# Set to True in production. When False, enables dev auth bypass and relaxed rate limits.
# Only change if you understand the security implications.
IS_PROD=True

# Compose mode
# Keep local-upstreams for full local Docker development.
# Set this blank when core-api should use remote AI/STT URLs instead of local upstream containers.
# docker-compose.override.yml is auto-loaded for local reload/bind-mount behavior.
COMPOSE_PROFILES=local-upstreams

# Public API bind
API_BIND_HOST=0.0.0.0
API_PORT=8000

# Local-only debug ports (used by docker-compose.debug.yml)
AI_PORT=8001
STT_PORT=8002
DB_PORT=5432
STORAGE_API_PORT=9000
STORAGE_CONSOLE_PORT=9001
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
LOKI_PORT=3100
POSTGRES_EXPORTER_PORT=9187
REDIS_EXPORTER_PORT=9121

# Upstream service URLs (core-api only)
AI_SERVICE_URL=http://ai-service:8000
STT_SERVICE_URL=http://stt-service:8000

# Credentials :

# Database
DB_USER=admin
DB_PASSWORD=secretpassword
DB_NAME=kidsmind_db

# Storage
STORAGE_ROOT_USER=admin
STORAGE_ROOT_PASSWORD=secretpassword

# Cache
CACHE_PASSWORD=secretpassword

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=secretpassword

# Logging Settings
# DEBUG in development, INFO in production
LOG_LEVEL=INFO



